# CloseReport — line ending policy
# Normalizes to LF in the repo; controls checkout per file type.
# Eliminates the "LF will be replaced by CRLF" warnings on Windows.

# Default: auto-detect text files, store as LF
* text=auto eol=lf

# PowerShell: CRLF on checkout (PS 5.1 safest with CRLF)
*.ps1 text eol=crlf

# Explicitly text — LF everywhere
*.py   text eol=lf
*.sql  text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.csv  text eol=lf
*.json text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary — no conversion
*.xlsx binary
*.xlsm binary
*.pdf  binary
*.png  binary
*.zip  binary
